# Copy this file to .env (or export these variables) to configure the server.
# All variables are OPTIONAL — the app runs without any of them.

# Port for the backend server (default 3001)
#PORT=3001

# Public URL of the app, used in password-reset links (default http://localhost:5173)
#APP_URL=https://ops.example.com

# Enable the AI features (AI Advisor, AI project briefs, AI email drafts,
# document auto-classification). Get a key at https://console.anthropic.com
#ANTHROPIC_API_KEY=sk-ant-...
# Override the Claude model (default claude-opus-4-8)
#ANTHROPIC_MODEL=claude-opus-4-8

# Enable outgoing email (report sending, sourcing emails).
#SMTP_URL=smtps://user:password@smtp.example.com:465
#SMTP_FROM=ops@example.com

# Set to true when serving over HTTPS so session cookies are Secure
#COOKIE_SECURE=true

# Where the SQLite database and uploaded files are stored (default server/data)
#DATA_DIR=/var/lib/opstrace
